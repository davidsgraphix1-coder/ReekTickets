# Frontend Environment Variables
# Copy this file to .env and .env.production, then update the values

# API Configuration
# For local development: http://localhost:5000/api
# For production: https://reektickets.com/api
REACT_APP_API_BASE=http://localhost:5000/api
REACT_APP_API_URL=http://localhost:5000/api

# Python SMS backend for automatic Zenoph SMS delivery
# Set this to the deployed Python SMS backend URL, e.g. https://reektickets-sms-backend-production.up.railway.app
PYTHON_SMS_BACKEND=

# Build settings
DISABLE_ESLINT_PLUGIN=true
CI=false
